rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Master Admin Helper (Merged from your version)
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == 'hPGom0p4tAfZf37Bqly6erLYkZm1' ||
        (request.auth.token.email != null && (
          request.auth.token.email.lower().matches('.*apranantham.*') ||
          request.auth.token.email.lower().matches('.*appuananth.*')
        ))
      );
    }

    // User Profiles: Staff sync their own, Admins see all
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
    }

    // Billing records: Admins see all, Staff see only what they created
    match /billing/{invoiceId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && (isAdmin() || resource.data.createdBy == request.auth.uid);
    }

    // Inventory and Service: All authenticated staff can manage
    match /inventory/{id} {
      allow read, write: if request.auth != null;
    }

    match /service/{id} {
      allow read, write: if request.auth != null;
    }
    
    // Shop Settings: Needed for invoice numbering!
    match /settings/shopProfile {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Everyone needs to increment nextInvoiceNumber
    }
    
    // Admin Catch-all for any other collections
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
